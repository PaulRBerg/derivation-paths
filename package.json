{
  "description": "Crypto HD derivation-path types, SLIP-44 data, and a single-source-of-truth path template engine.",
  "homepage": "https://github.com/PaulRBerg/derivation-paths#readme",
  "license": "MIT",
  "main": "./dist/index.js",
  "name": "@prb/derivation-paths",
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "1.4.0",
  "files": [
    "dist/**"
  ],
  "keywords": [
    "bip32",
    "bip44",
    "derivation-path",
    "hd-wallet",
    "slip44",
    "slip132",
    "cryptocurrency"
  ],
  "author": {
    "name": "Paul Razvan Berg",
    "url": "https://github.com/PaulRBerg"
  },
  "bugs": {
    "url": "https://github.com/PaulRBerg/derivation-paths/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@prb/devkit": "^1.0.0",
    "@types/node": "^25.0.3",
    "@vitest/ui": "^4.0.16",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "ultracite": "^7.0.12",
    "vitest": "^4.0.16"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./coin-types": {
      "types": "./dist/slip44.d.ts",
      "import": "./dist/slip44.js"
    },
    "./purposes": {
      "types": "./dist/purposes.d.ts",
      "import": "./dist/purposes.js"
    },
    "./schemes": {
      "types": "./dist/schemes.d.ts",
      "import": "./dist/schemes.js"
    },
    "./slip132": {
      "types": "./dist/slip132.d.ts",
      "import": "./dist/slip132.js"
    },
    "./path": {
      "types": "./dist/path/index.d.ts",
      "import": "./dist/path/index.js"
    },
    "./substrate-suri": {
      "types": "./dist/substrate-suri.d.ts",
      "import": "./dist/substrate-suri.js"
    },
    "./profiles": {
      "types": "./dist/profiles/index.d.ts",
      "import": "./dist/profiles/index.js"
    },
    "./descriptors": {
      "types": "./dist/descriptors.d.ts",
      "import": "./dist/descriptors.js"
    },
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PaulRBerg/derivation-paths.git"
  },
  "scripts": {
    "setup": "husky"
  }
}

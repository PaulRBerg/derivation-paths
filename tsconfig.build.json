{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./node_modules/@prb/devkit/tsconfig/build.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "exclude": ["./node_modules", "./src/**/*.test.ts"],
